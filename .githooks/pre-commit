#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# PenPard pre-commit hook
# Blocks commits that include sensitive file types or secret-like patterns.
#
# Install:  cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or set:   git config core.hooksPath .githooks
# ─────────────────────────────────────────────────────────────────────────────

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

BLOCKED_EXTENSIONS=(
  "\.pdf$"
  "\.docx?$"
  "\.har$"
  "\.pcap$"
  "\.pcapng$"
  "\.cap$"
  "\.pem$"
  "\.key$"
  "\.p12$"
  "\.pfx$"
  "\.sqlite$"
  "\.sqlite3$"
  "\.db$"
  "\.env$"
)

SECRET_PATTERNS=(
  "Authorization: Bearer [A-Za-z0-9\-_]+\.[A-Za-z0-9\-_]+"
  "api[_-]?key\s*[:=]\s*['\"][A-Za-z0-9]{20,}"
  "client_secret\s*[:=]\s*['\"][A-Za-z0-9]{12,}"
  "-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----"
)

ERRORS=0

# ── Check staged file extensions ──────────────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for pattern in "${BLOCKED_EXTENSIONS[@]}"; do
  MATCHES=$(echo "$STAGED_FILES" | grep -iE "$pattern" || true)
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}[pre-commit] BLOCKED: Sensitive file type detected:${NC}"
    echo "$MATCHES"
    ERRORS=$((ERRORS+1))
  fi
done

# ── Check staged content for secret patterns ──────────────────────────────────
for pattern in "${SECRET_PATTERNS[@]}"; do
  MATCHES=$(git diff --cached -U0 | grep "^+" | grep -iE "$pattern" || true)
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}[pre-commit] BLOCKED: Secret-like pattern detected:${NC}"
    echo -e "${YELLOW}Pattern: ${pattern}${NC}"
    echo "$MATCHES" | head -5
    ERRORS=$((ERRORS+1))
  fi
done

# ── Warn about known sensitive directories ────────────────────────────────────
SENSITIVE_DIRS=("backend/uploads" "backend/logs" "reports/" "samples/")
for dir in "${SENSITIVE_DIRS[@]}"; do
  MATCHES=$(echo "$STAGED_FILES" | grep "^$dir" || true)
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}[pre-commit] BLOCKED: File from sensitive directory staged:${NC}"
    echo "$MATCHES"
    ERRORS=$((ERRORS+1))
  fi
done

if [ "$ERRORS" -gt 0 ]; then
  echo ""
  echo -e "${RED}══════════════════════════════════════════════════════════${NC}"
  echo -e "${RED}  COMMIT BLOCKED: $ERRORS sensitive item(s) detected.${NC}"
  echo -e "${RED}  Remove the files/patterns, then retry.${NC}"
  echo -e "${RED}  See SECURITY.md for guidance.${NC}"
  echo -e "${RED}══════════════════════════════════════════════════════════${NC}"
  exit 1
fi

echo "[pre-commit] Security check passed."
exit 0
